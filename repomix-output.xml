  border-radius: 50%;
  background: rgba(93, 70, 56, 0.16);
  color: #6a4b39;
  font-size: 28px;
  line-height: 1;
  cursor: pointer;
}

.event-modal-icon {
  font-size: 58px;
  margin-bottom: 8px;
}

.event-modal h2 {
  margin: 0 0 10px;
  font-size: 28px;
  letter-spacing: -0.05em;
}

.event-modal p {
  margin: 0;
  line-height: 1.6;
  font-weight: 800;
  white-space: pre-line;
}

.event-modal-reward {
  margin-top: 20px;
  padding: 13px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.55);
  display: flex;
  justify-content: space-between;
  gap: 12px;
  font-weight: 900;
}

.event-modal-reward span {
  color: #9f7654;
}

.event-modal-reward strong {
  color: #5e3f2e;
}

@media (max-width: 1320px) {
  .game-root {
    min-width: 100vw;
    min-height: 700px;
  }

  .resource-chip {
    min-width: 142px;
  }

  .resource-chip strong {
    font-size: 18px;
  }

  .game-screen {
    grid-template-columns: 295px 1fr 285px;
  }

  .action-button strong {
    font-size: 18px;
  }
}

@media (max-width: 1080px) {
  body {
    overflow: auto;
  }

  .game-root {
    min-height: 1180px;
    height: auto;
    overflow: hidden;
  }

  .top-hud {
    position: relative;
    top: auto;
    left: auto;
    right: auto;
    padding: 16px;
    flex-direction: column;
    align-items: stretch;
  }

  .profile-card {
    width: 100%;
  }

  .resource-row {
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .resource-chip,
  .time-chip {
    flex: 0 0 auto;
  }

  .game-screen {
    position: relative;
    inset: auto;
    padding: 0 16px 150px;
    grid-template-columns: 1fr;
  }

  .center-stage {
    min-height: 460px;
    order: -1;
  }

  .bottom-actions {
    position: fixed;
    left: 10px;
    right: 10px;
    bottom: 10px;
    grid-template-columns: 54px 1fr 54px;
    min-height: 96px;
    padding: 8px;
    gap: 8px;
  }

  .action-row {
    display: flex;
    overflow-x: auto;
    gap: 8px;
  }

  .action-button {
    flex: 0 0 118px;
    height: 86px;
    border-radius: 18px;
  }

  .action-sprite {
    display: none;
  }

  .side-button {
    height: 76px;
  }

  .mini-character {
    transform: scale(0.82);
  }

  .mini-coding {
    left: 6%;
    top: 10%;
  }

  .mini-exercise {
    right: 8%;
    top: 12%;
  }
}

@media (max-width: 640px) {
  .profile-title strong {
    font-size: 24px;
  }

  .profile-title span {
    font-size: 24px;
  }

  .resource-row {
    display: none;
  }

  .game-root {
    min-height: 1100px;
  }

  .stat-panel,
  .inventory-panel,
  .message-panel {
    border-radius: 22px;
  }

  .center-stage {
    min-height: 390px;
  }

  .main-bubble {
    top: 0;
    font-size: 13px;
  }

  .floating-status {
    display: none;
  }

  .mini-sprite {
    width: 72px;
    height: 72px;
  }

  .mini-bubble {
    font-size: 11px;
  }

  .bottom-actions {
    grid-template-columns: 1fr;
  }

  .side-button {
    display: none;
  }
}
</file>

