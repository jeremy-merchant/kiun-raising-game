  align-items: center;
  gap: 10px;
  color: #dbc8b5;
  font-size: 13px;
}

.bar {
  width: 100%;
  height: 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #ffcf93, #f5a45b);
}

.exp-fill {
  background: linear-gradient(90deg, #ad7cff, #ef9cff);
}

.stage-card {
  padding: 20px;
}

.stage-top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 18px;
}

.stage-top h2 {
  margin: 4px 0;
  font-size: 26px;
}

.secondary-button,
.danger-button {
  border: 0;
  border-radius: 14px;
  padding: 12px 16px;
  cursor: pointer;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.secondary-button:hover,
.danger-button:hover,
.action-card:hover,
.gallery-card:hover {
  transform: translateY(-2px);
}

.secondary-button {
  background: #dcb789;
  color: #271d16;
  font-weight: 700;
}

.danger-button {
  background: #9b5555;
  color: white;
  font-weight: 700;
}

.stage-main {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 18px;
  align-items: stretch;
}

.stage-image-wrap {
  min-height: 520px;
  border-radius: 24px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 244, 229, 0.08);
}

.stage-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.stage-info {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.speech-bubble,
.quote-box,
.profile-box,
.mini-card {
  background: rgba(255, 247, 237, 0.05);
  border: 1px solid rgba(255, 240, 218, 0.08);
  border-radius: 18px;
}

.speech-bubble {
  padding: 16px 18px;
  font-size: 16px;
  line-height: 1.6;
  color: #fff1e1;
}

.quote-box,
.profile-box {
  padding: 16px 18px;
}

.quote-box p,
.profile-box p {
  margin: 8px 0 0;
  line-height: 1.7;
  color: #ebdfd2;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(230, 187, 135, 0.14);
  border: 1px solid rgba(235, 200, 154, 0.18);
  color: #f6d9b5;
  font-size: 13px;
}

.achievement-tag {
  background: rgba(255, 223, 123, 0.12);
  color: #ffe08a;
}

.mini-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.mini-card {
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.mini-card strong {
  color: #ffe0bc;
}

.mini-card span {
  color: #d9c9bc;
  font-size: 14px;
  line-height: 1.5;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.action-card {
  text-align: left;
  border: 1px solid rgba(255, 235, 214, 0.08);
  background: linear-gradient(180deg, rgba(255, 240, 219, 0.07), rgba(255, 240, 219, 0.04));
  border-radius: 18px;
  padding: 16px;
  color: inherit;
  cursor: pointer;
  transition: transform 0.15s ease, border-color 0.15s ease;
}

.action-card:hover {
  border-color: rgba(255, 206, 142, 0.4);
}

.action-card-top {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

.action-emoji {
  font-size: 28px;
}

.action-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.action-title-wrap span {
  color: #c9b6a4;
  font-size: 12px;
}

.action-card p {
  margin: 0 0 12px;
  color: #d9cbc0;
  line-height: 1.6;
  min-height: 48px;
}

.action-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  color: #f0d3ab;
  font-size: 12px;
}

.inventory-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.inventory-card {
  padding: 14px;
  border-radius: 16px;
  background: rgba(255, 250, 243, 0.05);
  border: 1px solid rgba(255, 240, 220, 0.08);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.inventory-head {
  display: flex;
  align-items: center;
  gap: 8px;
}

.inventory-icon {
  font-size: 20px;
}

.inventory-count {
  color: #ffdaa9;
  font-weight: 700;
}

.inventory-card p {
  margin: 0;
  color: #cdbdaf;
  font-size: 13px;
  line-height: 1.5;
}

.achievement-box {
  margin-top: 16px;
}

.achievement-box h3 {
  margin: 0 0 10px;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  max-height: 520px;
  overflow: auto;
  padding-right: 4px;
}

.log-item {
  padding: 12px 14px;
  border-radius: 16px;
  border: 1px solid rgba(255, 240, 220, 0.08);
  background: rgba(255, 250, 243, 0.04);
}

.log-activity {
  border-left: 4px solid #c98a49;
}

.log-event {
  border-left: 4px solid #9d7aff;
}

.log-system {
  border-left: 4px solid #6db3ff;
}

.log-meta {
  display: flex;
  gap: 10px;
  color: #c6b19b;
  font-size: 12px;
  margin-bottom: 6px;
}

.log-item p {
  margin: 0;
  line-height: 1.6;
  color: #e8dccf;
}

.gallery-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.gallery-card {
  border: 1px solid rgba(255, 235, 214, 0.08);
  background: rgba(255, 248, 238, 0.05);
  color: inherit;
  border-radius: 18px;
  overflow: hidden;
  cursor: pointer;
  text-align: left;
}

.gallery-card.active {
  border-color: #f4c58d;
  box-shadow: 0 0 0 1px rgba(244, 197, 141, 0.4);
}

.gallery-card img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
}

.gallery-card-body {
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.gallery-card-body span {
  color: #bca894;
  text-transform: capitalize;
  font-size: 12px;
}

.footer-bar {
  padding: 18px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.footer-left {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.footer-left p {
  margin: 0;
}

.footer-actions {
  display: flex;
  gap: 10px;
}

@media (max-width: 1280px) {
  .main-grid {
    grid-template-columns: 1fr;
  }

  .left-column,
  .center-column,
  .right-column {
    width: 100%;
  }
}

@media (max-width: 980px) {
  .topbar {
    flex-direction: column;
    align-items: stretch;
  }

  .topbar-resources {
    justify-content: flex-start;
  }

  .stage-main {
    grid-template-columns: 1fr;
  }

  .action-grid,
  .gallery-grid,
  .inventory-grid,
  .mini-grid {
    grid-template-columns: 1fr;
  }

  .footer-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .footer-actions {
    width: 100%;
    flex-direction: column;
  }
}

@media (max-width: 640px) {
  .app-shell {
    padding: 14px;
  }

  .topbar-profile-text h1 {
    font-size: 24px;
  }

  .stage-image-wrap {
    min-height: 320px;
  }
}
